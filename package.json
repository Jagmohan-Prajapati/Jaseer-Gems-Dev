    "@vitejs/plugin-react": "^5.0.4",
    "bcrypt": "^6.0.0",
    "cloudinary": "^2.10.0",
    "clsx": "^2.1.1",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "jose": "^6.2.3",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "multer": "^2.1.1",
    "prisma": "^6.19.3",
    "razorpay": "^2.9.6",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-router-dom": "^7.15.1",
